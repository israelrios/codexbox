#!/usr/bin/env python3

import argparse
import ast
import fnmatch
import json
import os
import re
import shlex
import stat
import subprocess
import sys
import tempfile
from collections.abc import Iterable
from dataclasses import dataclass, field
from pathlib import Path
from typing import cast


CONTAINER_RUNTIME = "podman"
DEFAULT_IMAGE = "codexbox:latest"
BASE_PATH = "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
BASE_PATH_SEGMENTS = set(BASE_PATH.split(":"))
EXCLUDED_MOUNT_PREFIXES = ("/usr", "/var")
PROFILE_SCRIPT_CONTAINER_PATH = "/etc/profile.d/codex-forwarded-path.sh"
PODMAN_STORAGE_CONF_CONTAINER_PATH = "/etc/containers/codexbox-storage.conf"
FUSE_DEVICE_PATH = "/dev/fuse"
FUSE_OVERLAYFS_PATH = "/usr/bin/fuse-overlayfs"
APPROVALS_CONFIG_FILE = ".codexbox-conf.json"
PODMAN_AUTO_MOUNT_RELATIVE_DIRS = (
    ".cache/containers",
    ".local/share/containers",
    ".config/containers",
)
GITCONFIG_RELATIVE_PATH = ".gitconfig"
GITHUB_CLI_CONFIG_RELATIVE_DIR = ".config/gh"
GITLAB_CLI_CONFIG_RELATIVE_DIR = ".config/glab-cli"


@dataclass(frozen=True)
class EnvMountCandidate:
    path: str
    resolved_path: str
    kind: str
    env_vars: tuple[str, ...]


@dataclass
class EnvMountCandidateDraft:
    resolved_path: str
    kind: str
    env_vars: list[str]


@dataclass(frozen=True)
class HostPodmanStore:
    graph_driver_name: str
    graph_root: str


@dataclass
class ParsedArgs(argparse.Namespace):
    image: str = DEFAULT_IMAGE
    rebuild: bool = False
    skip_build: bool = False
    print_command: bool = False
    dry_run: bool = False
    codex_args: list[str] = field(default_factory=list)


def parse_args() -> ParsedArgs:
    parser = argparse.ArgumentParser(
        description=(
            "Start a temporary Podman container in the current shell directory "
            "and launch Codex in yolo mode."
        )
    )
    _ = parser.add_argument(
        "--image",
        default=DEFAULT_IMAGE,
        help=f"Podman image to run or build (default: {DEFAULT_IMAGE})",
    )
    _ = parser.add_argument(
        "--rebuild",
        action="store_true",
        help="Force a rebuild of the Podman image before launching.",
    )
    _ = parser.add_argument(
        "--skip-build",
        action="store_true",
        help="Do not build the Podman image automatically if it is missing.",
    )
    _ = parser.add_argument(
        "--print-command",
        action="store_true",
        help="Print the generated podman command before executing it.",
    )
    _ = parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the generated podman command and exit without running it.",
    )
    _ = parser.add_argument(
        "codex_args",
        nargs=argparse.REMAINDER,
        help="Arguments forwarded to codex. Prefix them with -- if needed.",
    )
    args = parser.parse_args(namespace=ParsedArgs())
    if args.codex_args and args.codex_args[0] == "--":
        args.codex_args = args.codex_args[1:]
    return args


def require_string_list(value: object, context: str) -> list[str]:
    if not isinstance(value, list):
        raise ValueError(f"Expected {context} to be a list of strings")

    raw_items = value
    items: list[str] = []
    for item in raw_items:
        if not isinstance(item, str):
            raise ValueError(f"Expected {context} to be a list of strings")
        items.append(item)
    return items


def require_string(value: object, context: str) -> str:
    if not isinstance(value, str):
        raise ValueError(f"Expected {context} to be a string")
    return value


def require_bool(value: object, context: str) -> bool:
    if not isinstance(value, bool):
        raise ValueError(f"Expected {context} to be a boolean")
    return value


def require_string_key_dict(value: object, context: str) -> dict[str, object]:
    if not isinstance(value, dict):
        raise ValueError(f"Expected {context} to be a JSON object")

    raw_items = value
    result: dict[str, object] = {}
    for key, item in raw_items.items():
        if not isinstance(key, str):
            raise ValueError(f"Expected {context} to contain only string keys")
        result[key] = item
    return result


def parse_writable_roots(config_path: Path) -> list[str]:
    section_name = "[sandbox_workspace_write]"
    in_section = False
    collecting = False
    roots: list[str] = []

    with config_path.open("r", encoding="utf-8") as handle:
        for raw_line in handle:
            line = raw_line.split("#", 1)[0].strip()
            if not line:
                continue

            if line.startswith("[") and line.endswith("]") and not collecting:
                in_section = line == section_name
                continue

            if not in_section:
                continue

            if collecting:
                if line == "]":
                    collecting = False
                    continue
                roots.append(parse_toml_string(line.rstrip(",")))
                continue

            if not line.startswith("writable_roots"):
                continue

            _, value = line.split("=", 1)
            value = value.strip()
            if value == "[":
                collecting = True
                continue
            if value.startswith("[") and value.endswith("]"):
                inline_items = cast(object, ast.literal_eval(value))
                return require_string_list(
                    inline_items,
                    "writable_roots in ~/.codex/config.toml",
                )
            raise ValueError(
                "Unsupported writable_roots format in ~/.codex/config.toml"
            )

    if collecting:
        raise ValueError("Unterminated writable_roots array in ~/.codex/config.toml")

    return roots


def parse_toml_string(value: str) -> str:
    value = value.strip()
    if not value:
        raise ValueError("Empty writable root entry in ~/.codex/config.toml")
    parsed_value = cast(object, ast.literal_eval(value))
    if not isinstance(parsed_value, str):
        raise ValueError("Writable root entry in ~/.codex/config.toml must be a string")
    return parsed_value


def ordered_unique(values: Iterable[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []
    for value in values:
        if value in seen:
            continue
        seen.add(value)
        result.append(value)
    return result


def split_path(value: str) -> list[str]:
    return [segment for segment in value.split(":") if segment]


def merge_path_values(preferred: str, fallback: str) -> str:
    return ":".join(ordered_unique([*split_path(preferred), *split_path(fallback)]))


def load_ignore_patterns(ignore_path: Path) -> list[str]:
    if not ignore_path.is_file():
        raise SystemExit(f"Missing ignore file: {ignore_path}")

    patterns: list[str] = []
    with ignore_path.open("r", encoding="utf-8") as handle:
        for raw_line in handle:
            line = raw_line.split("#", 1)[0].strip()
            if not line:
                continue
            patterns.append(line.split("=", 1)[0].strip())
    return patterns


def is_ignored_env_var(name: str, patterns: Iterable[str]) -> bool:
    return any(fnmatch.fnmatch(name, pattern) for pattern in patterns)


def filtered_shell_env(ignore_path: Path) -> dict[str, str]:
    patterns = load_ignore_patterns(ignore_path)
    env_map: dict[str, str] = {}
    for key, value in os.environ.items():
        if is_ignored_env_var(key, patterns):
            continue
        env_map[key] = value
    return env_map


def shell_pwd() -> Path:
    shell_pwd_value = os.environ.get("PWD")
    if shell_pwd_value:
        shell_pwd = Path(shell_pwd_value)
        if shell_pwd.is_absolute():
            return shell_pwd
    return Path.cwd()


def container_tty_flags() -> list[str]:
    flags: list[str] = []
    if not sys.stdin.closed:
        flags.append("-i")
    if sys.stdin.isatty() and sys.stdout.isatty():
        flags.append("-t")
    return flags


def container_env_flags(env_map: dict[str, str]) -> list[str]:
    flags: list[str] = []
    for name in ordered_unique(env_map):
        flags.extend(["--env", f"{name}={env_map[name]}"])
    return flags


def podman_runtime_env() -> dict[str, str]:
    env_map = dict(os.environ)
    env_map.pop("CONTAINER_CONNECTION", None)
    env_map.pop("CONTAINER_HOST", None)
    # Rootless Podman maps container root back to the invoking host user by default.
    env_map["PODMAN_USERNS"] = ""
    return env_map


def load_podman_info(runtime_env: dict[str, str]) -> dict[str, object]:
    try:
        completed = subprocess.run(
            [CONTAINER_RUNTIME, "info", "--format", "{{json .}}"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            env=runtime_env,
            check=False,
        )
    except FileNotFoundError as exc:
        raise SystemExit(f"Missing container runtime: {CONTAINER_RUNTIME}") from exc

    if completed.returncode != 0:
        message = completed.stderr.strip() or f"Unable to query {CONTAINER_RUNTIME} info."
        raise SystemExit(message)

    try:
        raw_info = cast(object, json.loads(completed.stdout.strip() or "{}"))
        return require_string_key_dict(raw_info, "Podman info")
    except (json.JSONDecodeError, ValueError) as exc:
        raise SystemExit(f"Unable to parse {CONTAINER_RUNTIME} info output.") from exc


def ensure_rootless_podman(podman_info: dict[str, object]) -> None:
    try:
        host_info = require_string_key_dict(
            podman_info.get("host"),
            "Podman host info",
        )
        security_info = require_string_key_dict(
            host_info.get("security"),
            "Podman host security info",
        )
        rootless = require_bool(
            security_info.get("rootless"),
            "Podman rootless flag",
        )
    except ValueError as exc:
        raise SystemExit(str(exc)) from exc

    if not rootless:
        raise SystemExit(
            "This launcher requires rootless Podman so container root maps back "
            "to the invoking host user."
        )


def image_env(image: str, runtime_env: dict[str, str]) -> dict[str, str]:
    completed = subprocess.run(
        [CONTAINER_RUNTIME, "image", "inspect", image, "--format", "{{json .Config.Env}}"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        env=runtime_env,
        check=False,
    )
    if completed.returncode != 0:
        return {}

    try:
        env_entries = cast(object, json.loads(completed.stdout.strip() or "[]"))
    except json.JSONDecodeError:
        return {}

    try:
        entries = require_string_list(env_entries, "image environment entries")
    except ValueError:
        return {}

    result: dict[str, str] = {}
    for entry in entries:
        if "=" not in entry:
            continue
        key, value = entry.split("=", 1)
        result[key] = value
    return result


def ensure_image(
    script_dir: Path,
    image: str,
    rebuild: bool,
    skip_build: bool,
    runtime_env: dict[str, str],
) -> None:
    inspect = subprocess.run(
        [CONTAINER_RUNTIME, "image", "inspect", image],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        env=runtime_env,
        check=False,
    )
    if inspect.returncode == 0 and not rebuild:
        return
    if skip_build:
        raise SystemExit(f"Podman image {image!r} was not found and --skip-build was used.")

    build_cmd = [CONTAINER_RUNTIME, "build", "--pull", "--tag", image, str(script_dir)]
    run_checked(build_cmd, env=runtime_env)


def run_checked(command: list[str], env: dict[str, str] | None = None) -> None:
    completed = subprocess.run(command, env=env, check=False)
    if completed.returncode != 0:
        raise SystemExit(completed.returncode)


def path_tokens(value: str) -> list[str]:
    tokens: list[str] = []
    for part in re.split(r"[\s:]+", value):
        if not part:
            continue
        for token in re.split(r"[=,;]", part):
            cleaned = token.strip("\"'()[],")
            if cleaned.startswith("/") and not cleaned.startswith("//"):
                tokens.append(cleaned.rstrip("/") or "/")
    return tokens


def mountable_path_kind(path: Path) -> str | None:
    try:
        path_stat = path.stat()
    except OSError:
        return None

    if stat.S_ISDIR(path_stat.st_mode):
        return "directory"
    if stat.S_ISREG(path_stat.st_mode):
        return "file"
    if stat.S_ISSOCK(path_stat.st_mode):
        return "socket"
    return None


def env_mount_candidates(env_map: dict[str, str]) -> list[EnvMountCandidate]:
    refs: dict[str, EnvMountCandidateDraft] = {}
    for key, value in env_map.items():
        for token in path_tokens(value):
            path = Path(token)
            path_str = str(path)
            if key == "PATH" and path_str in BASE_PATH_SEGMENTS:
                continue
            if path_str.startswith(EXCLUDED_MOUNT_PREFIXES):
                continue

            kind = mountable_path_kind(path)
            if kind is None:
                continue

            resolved_path = str(path.resolve())
            entry = refs.setdefault(
                path_str,
                EnvMountCandidateDraft(
                    resolved_path=resolved_path,
                    kind=kind,
                    env_vars=[],
                ),
            )
            if key not in entry.env_vars:
                entry.env_vars.append(key)

    return [
        EnvMountCandidate(
            path=path,
            resolved_path=data.resolved_path,
            kind=data.kind,
            env_vars=tuple(data.env_vars),
        )
        for path, data in refs.items()
    ]


def write_path_profile(script_path: Path, forwarded_path: str) -> None:
    lines = ["#!/bin/sh"]
    for segment in reversed(split_path(forwarded_path)):
        quoted_segment = shlex.quote(segment)
        lines.extend(
            [
                f"_codex_path={quoted_segment}",
                'case ":$PATH:" in',
                '  *":${_codex_path}:"*) ;;',
                '  *) PATH="${_codex_path}${PATH:+:$PATH}" ;;',
                "esac",
            ]
        )
    lines.extend(["export PATH", "unset _codex_path"])
    _ = script_path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def write_podman_storage_conf(
    config_path: Path,
    use_fuse_overlayfs: bool,
    additional_image_stores: Iterable[str] = (),
) -> None:
    # Nested Podman runs on top of the outer container filesystem. Prefer
    # fuse-overlayfs when the binary and /dev/fuse are available, otherwise
    # fall back to vfs to avoid overlay-on-overlay failures.
    driver = "overlay" if use_fuse_overlayfs else "vfs"
    lines = [
        "[storage]",
        f'driver = "{driver}"',
        'graphroot = "/var/lib/containers/storage"',
        'runroot = "/run/containers/storage"',
    ]
    ordered_image_stores = ordered_unique(additional_image_stores)
    if ordered_image_stores:
        additional_store_list = ", ".join(
            json.dumps(path) for path in ordered_image_stores
        )
        lines.extend(
            [
                "",
                "[storage.options]",
                f"additionalimagestores = [{additional_store_list}]",
            ]
        )
    if use_fuse_overlayfs:
        lines.extend(
            [
                "",
                "[storage.options.overlay]",
                f'mount_program = "{FUSE_OVERLAYFS_PATH}"',
            ]
        )
    _ = config_path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def host_fuse_device_available() -> bool:
    try:
        device_stat = Path(FUSE_DEVICE_PATH).stat()
    except OSError:
        return False
    return stat.S_ISCHR(device_stat.st_mode)


def image_has_fuse_overlayfs(image: str, runtime_env: dict[str, str]) -> bool:
    completed = subprocess.run(
        [
            CONTAINER_RUNTIME,
            "run",
            "--rm",
            "--entrypoint",
            "sh",
            image,
            "-c",
            f"test -x {shlex.quote(FUSE_OVERLAYFS_PATH)}",
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        env=runtime_env,
        check=False,
    )
    return completed.returncode == 0


def host_ca_setup() -> tuple[dict[str, str], list[str]]:
    env_updates: dict[str, str] = {}
    mount_paths: list[str] = []

    cert_dir_candidates = [os.environ.get("SSL_CERT_DIR"), "/etc/ssl/certs"]
    cert_dir = next(
        (candidate for candidate in cert_dir_candidates if candidate and Path(candidate).is_dir()),
        None,
    )
    cert_file_candidates = [
        os.environ.get("SSL_CERT_FILE"),
        "/etc/ssl/certs/ca-certificates.crt",
    ]
    cert_file = next(
        (candidate for candidate in cert_file_candidates if candidate and Path(candidate).is_file()),
        None,
    )

    if cert_dir:
        env_updates["SSL_CERT_DIR"] = cert_dir
        mount_paths.append(cert_dir)
    if cert_file:
        env_updates["CURL_CA_BUNDLE"] = cert_file
        env_updates["GIT_SSL_CAINFO"] = cert_file
        env_updates["NODE_EXTRA_CA_CERTS"] = cert_file
        env_updates["REQUESTS_CA_BUNDLE"] = cert_file
        env_updates["SSL_CERT_FILE"] = cert_file

    return env_updates, ordered_unique(mount_paths)


def host_podman_store(podman_info: dict[str, object]) -> HostPodmanStore | None:
    try:
        store = require_string_key_dict(
            podman_info.get("store"),
            "Podman store info",
        )
        graph_driver_name = require_string(
            store.get("graphDriverName"),
            "Podman graph driver name",
        ).strip()
        graph_root = require_string(
            store.get("graphRoot"),
            "Podman graph root",
        ).strip()
    except ValueError:
        return None

    if not graph_driver_name or not graph_root:
        return None

    return HostPodmanStore(
        graph_driver_name=graph_driver_name,
        graph_root=graph_root,
    )


def host_podman_additional_image_store(
    podman_info: dict[str, object],
    home_dir: Path,
    use_fuse_overlayfs: bool,
) -> str | None:
    # Reuse only the host image store, not the writable graphroot, so nested
    # Podman can see already-pulled layers without sharing the live writable
    # state between the host and the inner container.
    if not use_fuse_overlayfs:
        return None

    store = host_podman_store(podman_info)
    if store is None or store.graph_driver_name != "overlay":
        return None

    graph_root = Path(store.graph_root).expanduser()
    if not graph_root.is_absolute() or not graph_root.is_dir():
        return None

    try:
        if graph_root.resolve() == home_dir.resolve():
            return None
    except OSError:
        return None

    return str(graph_root)


def host_podman_mount_paths(home_dir: Path) -> list[str]:
    return ordered_unique(
        [
            str(path)
            for path in (home_dir / rel_path for rel_path in PODMAN_AUTO_MOUNT_RELATIVE_DIRS)
            if path.is_dir()
        ]
    )


def host_gitconfig_mount_paths(home_dir: Path) -> list[str]:
    gitconfig_path = home_dir / GITCONFIG_RELATIVE_PATH
    if not gitconfig_path.is_file():
        return []
    return [str(gitconfig_path)]


def host_github_cli_mount_paths(home_dir: Path) -> list[str]:
    gh_config_dir = home_dir / GITHUB_CLI_CONFIG_RELATIVE_DIR
    if not gh_config_dir.is_dir():
        return []
    return [str(gh_config_dir)]


def host_gitlab_cli_mount_paths(home_dir: Path) -> list[str]:
    glab_config_dir = home_dir / GITLAB_CLI_CONFIG_RELATIVE_DIR
    if not glab_config_dir.is_dir():
        return []
    return [str(glab_config_dir)]


def is_same_or_parent(parent: str, child: str) -> bool:
    try:
        _ = Path(child).relative_to(parent)
        return True
    except ValueError:
        return False


def is_covered_by_mounts(path: str, specs: Iterable[tuple[str, str]]) -> bool:
    return any(is_same_or_parent(existing_path, path) for existing_path, _ in specs)


def merge_mount_specs(specs: Iterable[tuple[str, str]]) -> list[tuple[str, str]]:
    ordered_specs: list[tuple[str, str]] = []
    for path, mode in specs:
        if mode == "ro" and any(
            existing_mode == "rw" and is_same_or_parent(existing_path, path)
            for existing_path, existing_mode in ordered_specs
        ):
            continue

        updated = False
        for index, (existing_path, existing_mode) in enumerate(ordered_specs):
            if existing_path != path:
                continue
            if existing_mode == "ro" and mode == "rw":
                ordered_specs[index] = (path, "rw")
            updated = True
            break
        if not updated:
            ordered_specs.append((path, mode))
    return ordered_specs


def load_env_mount_approvals(approvals_path: Path) -> set[str]:
    if not approvals_path.is_file():
        return set()

    try:
        raw_data = cast(object, json.loads(approvals_path.read_text(encoding="utf-8")))
    except (OSError, json.JSONDecodeError) as exc:
        raise SystemExit(f"Invalid env mount approvals file {approvals_path}: {exc}") from exc

    try:
        data = require_string_key_dict(raw_data, f"env mount approvals file {approvals_path}")
    except ValueError as exc:
        raise SystemExit(str(exc)) from exc

    try:
        approved_paths = require_string_list(
            data.get("approved_paths", []),
            f"approved_paths in {approvals_path}",
        )
    except ValueError as exc:
        raise SystemExit(str(exc)) from exc

    return set(approved_paths)


def save_env_mount_approvals(approvals_path: Path, approved_paths: Iterable[str]) -> None:
    data = {
        "approved_paths": ordered_unique(sorted(approved_paths)),
    }
    _ = approvals_path.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")


def confirm_env_mount_candidates(
    approvals_path: Path, candidates: list[EnvMountCandidate]
) -> set[str]:
    if not candidates:
        return set()

    if not sys.stdin.isatty() or not sys.stderr.isatty():
        candidate_list = "\n".join(f"  - {candidate.path}" for candidate in candidates)
        message = (
            "Approval is required before bind-mounting env-var-derived paths.\n"
            + f"Run the launcher interactively to approve these paths:\n{candidate_list}"
        )
        raise SystemExit(
            message
        )

    print(
        "Approval required for env-var-derived bind mounts.",
        file=sys.stderr,
    )
    print(
        f"Approved paths will be saved to {approvals_path}.",
        file=sys.stderr,
    )
    for candidate in candidates:
        env_vars = ", ".join(candidate.env_vars)
        print(
            f"  - {candidate.path} ({candidate.kind}; from {env_vars})",
            file=sys.stderr,
        )

    response = input("Allow and remember these bind mounts? [y/N]: ").strip().lower()
    if response not in {"y", "yes"}:
        print("Skipping unapproved env-var-derived bind mounts.", file=sys.stderr)
        return set()

    approved_paths = {candidate.path for candidate in candidates}
    approvals_path.parent.mkdir(parents=True, exist_ok=True)
    existing_approvals = load_env_mount_approvals(approvals_path)
    save_env_mount_approvals(approvals_path, existing_approvals | approved_paths)
    return approved_paths


def main() -> None:
    args = parse_args()
    script_dir = Path(__file__).resolve().parent
    home_dir = Path.home()
    codex_dir = home_dir / ".codex"
    config_path = codex_dir / "config.toml"
    approvals_path = home_dir / APPROVALS_CONFIG_FILE
    ignore_path = script_dir / "vars-to-ignore.txt"
    cwd = shell_pwd()

    if not config_path.is_file():
        raise SystemExit(f"Missing Codex config: {config_path}")
    if not cwd.is_dir():
        raise SystemExit(f"Current directory does not exist: {cwd}")
    if not codex_dir.is_dir():
        raise SystemExit(f"Missing Codex directory: {codex_dir}")

    runtime_env = podman_runtime_env()
    podman_info = load_podman_info(runtime_env)
    ensure_rootless_podman(podman_info)

    if not args.dry_run:
        ensure_image(
            script_dir,
            args.image,
            args.rebuild,
            args.skip_build,
            runtime_env,
        )
    use_fuse_overlayfs = host_fuse_device_available() and image_has_fuse_overlayfs(
        args.image,
        runtime_env,
    )

    shell_env = filtered_shell_env(ignore_path)
    writable_roots = parse_writable_roots(config_path)
    existing_roots: list[str] = []
    for root in writable_roots:
        path = Path(os.path.expanduser(root))
        if path.is_dir():
            existing_roots.append(str(path))
    existing_roots = ordered_unique(existing_roots)

    current_path = shell_env.get("PATH", os.environ.get("PATH", BASE_PATH))
    container_path = image_env(args.image, runtime_env).get("PATH", BASE_PATH)
    forwarded_path = merge_path_values(current_path, container_path)
    directory_env_map = dict(shell_env)
    directory_env_map["PATH"] = current_path
    env_candidates = env_mount_candidates(directory_env_map)
    ca_env, ca_mount_paths = host_ca_setup()
    podman_mount_paths = host_podman_mount_paths(home_dir)
    podman_additional_image_store = host_podman_additional_image_store(
        podman_info,
        home_dir,
        use_fuse_overlayfs,
    )
    gitconfig_mount_paths = host_gitconfig_mount_paths(home_dir)
    github_cli_mount_paths = host_github_cli_mount_paths(home_dir)
    gitlab_cli_mount_paths = host_gitlab_cli_mount_paths(home_dir)
    forwarded_env = dict(shell_env)
    forwarded_env.update(ca_env)
    forwarded_env["HOME"] = str(home_dir)
    forwarded_env["PWD"] = str(cwd)
    forwarded_env["PATH"] = forwarded_path
    forwarded_env["BASH_ENV"] = PROFILE_SCRIPT_CONTAINER_PATH
    # The container runs as root. Keep USER/LOGNAME aligned with the actual
    # in-container identity so nested rootless Podman resolves subuid/subgid
    # entries for root instead of a forwarded host username.
    forwarded_env["USER"] = "root"
    forwarded_env["LOGNAME"] = "root"
    # Nested rootless Podman cannot reliably mount proc through the OCI
    # runtime in this container, so prefer chroot isolation for build steps
    # unless the caller explicitly chose another mode.
    forwarded_env.setdefault("BUILDAH_ISOLATION", "chroot")
    base_mount_specs = merge_mount_specs(
        [
            (str(cwd), "rw"),
            (str(codex_dir), "rw"),
            *((path, "rw") for path in existing_roots),
            *((path, "rw") for path in podman_mount_paths),
            *(
                [(podman_additional_image_store, "ro")]
                if podman_additional_image_store
                else []
            ),
            *((path, "ro") for path in gitconfig_mount_paths),
            *((path, "ro") for path in github_cli_mount_paths),
            *((path, "ro") for path in gitlab_cli_mount_paths),
            *((path, "ro") for path in ca_mount_paths),
        ]
    )
    saved_approvals = load_env_mount_approvals(approvals_path)
    home_resolved = str(home_dir.resolve())
    current_approved_specs = merge_mount_specs(
        [
            *base_mount_specs,
            *(
                (candidate.path, "ro")
                for candidate in env_candidates
                if candidate.path in saved_approvals and candidate.resolved_path != home_resolved
            ),
        ]
    )
    blocked_home_candidates: list[EnvMountCandidate] = []
    pending_candidates: list[EnvMountCandidate] = []
    approved_env_paths: list[str] = []

    for candidate in env_candidates:
        if is_covered_by_mounts(candidate.path, base_mount_specs):
            continue
        if candidate.resolved_path == home_resolved:
            blocked_home_candidates.append(candidate)
            continue
        if is_covered_by_mounts(candidate.path, current_approved_specs):
            if candidate.path in saved_approvals:
                approved_env_paths.append(candidate.path)
            continue
        pending_candidates.append(candidate)

    if blocked_home_candidates:
        print(
            "Skipping env-var-derived mounts of the home directory root:",
            file=sys.stderr,
        )
        for candidate in blocked_home_candidates:
            env_vars = ", ".join(candidate.env_vars)
            print(f"  - {candidate.path} (from {env_vars})", file=sys.stderr)

    newly_approved_paths = confirm_env_mount_candidates(approvals_path, pending_candidates)
    mount_specs = merge_mount_specs(
        [
            *base_mount_specs,
            *((path, "ro") for path in approved_env_paths),
            *((path, "ro") for path in sorted(newly_approved_paths)),
        ]
    )
    with tempfile.TemporaryDirectory(prefix="codexbox-") as temp_dir:
        path_profile = Path(temp_dir) / "codex-forwarded-path.sh"
        podman_storage_conf = Path(temp_dir) / "codexbox-storage.conf"
        write_path_profile(path_profile, current_path)
        write_podman_storage_conf(
            podman_storage_conf,
            use_fuse_overlayfs,
            [podman_additional_image_store] if podman_additional_image_store else [],
        )
        forwarded_env["CONTAINERS_STORAGE_CONF"] = PODMAN_STORAGE_CONF_CONTAINER_PATH

        container_cmd: list[str] = [
            CONTAINER_RUNTIME,
            "run",
            "--rm",
            "--init",
            "--network",
            "host",
            *container_tty_flags(),
            *container_env_flags(forwarded_env),
            "--workdir",
            str(cwd),
        ]
        if use_fuse_overlayfs:
            container_cmd.extend(["--device", FUSE_DEVICE_PATH])
        for path, mode in mount_specs:
            mount_spec = f"{path}:{path}"
            if mode == "ro":
                mount_spec = f"{mount_spec}:ro"
            container_cmd.extend(["-v", mount_spec])
        container_cmd.extend(
            [
                "-v",
                f"{path_profile}:{PROFILE_SCRIPT_CONTAINER_PATH}:ro",
                "-v",
                f"{podman_storage_conf}:{PODMAN_STORAGE_CONF_CONTAINER_PATH}:ro",
            ]
        )

        container_cmd.append(args.image)
        container_cmd.extend(
            [
                "--dangerously-bypass-approvals-and-sandbox",
                "-C",
                str(cwd),
            ]
        )
        for root in ordered_unique(existing_roots):
            if root == str(cwd):
                continue
            container_cmd.extend(["--add-dir", root])
        container_cmd.extend(args.codex_args)

        if args.print_command or args.dry_run:
            print(shlex.join(container_cmd))

        if args.dry_run:
            return

        run_checked(container_cmd, env=runtime_env)


def handle_keyboard_interrupt() -> None:
    print(file=sys.stderr)
    raise SystemExit(130)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        handle_keyboard_interrupt()
